# Anthropic Claude API Key
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# App Config (optional)
APP_NAME=Afya AI
APP_ENV=development
APP_URL=http://localhost:8000
